<%- include('../partials/header') %>
<div class="page-container stone-wall torch-flicker">
    <div class="scroll-container vertical-scroll">
        <div class="crest gold-embossed">Xshift</div>
        
        <form action="/login" method="POST" class="magic-form">
            <div class="input-slot parchment-slot">
                <label>USERNAME</label>
                <input type="text" name="username" class="sepia-ink" placeholder="Enter your moniker..." required>
            </div>
            
            <div class="input-slot parchment-slot">
                <label>PASSWORD</label>
                <input type="password" name="password" class="sepia-ink" placeholder="•••••••••" required>
            </div>
            
            <button type="submit" class="heavy-iron-btn emerald-glow">Enter the Sanctum</button>
        </form>
    </div>
</div>
</body>
</html>
